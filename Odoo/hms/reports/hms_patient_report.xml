<odoo>
    <data>
        <record id="action_hms_patient_report" model="ir.actions.report">
            <field name="name">Patient Status Report</field>
            <field name="model">hms.patient</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hms.report_hms_patient_template</field>
            <field name="report_file">hms.report_hms_patient_template</field>
            <field name="binding_model_id" ref="model_hms_patient"/>
            <field name="binding_type">report</field>
        </record>

        <template id="report_hms_patient_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="patient">
                    <t t-call="web.external_layout">
                        <div class="page">
                            
                            <h2>Patient Status Report</h2>
                            
                            <p><strong>Name:</strong> <t t-out="patient.name"/></p>
                            <p><strong>Birth Date:</strong> <t t-out="patient.birth_date"/></p>
                            <p><strong>Age:</strong> <t t-out="patient.age"/></p>
                            <p><strong>Email:</strong> <t t-out="patient.email or 'N/A'"/></p>
                            <p><strong>PCR Test Check:</strong> <t t-out="patient.pcr"/></p>
                            <p><strong>CR Ratio:</strong> <t t-out="patient.cr_ratio"/></p>
                            <p><strong>Department:</strong> <t t-out="patient.department_id.name or 'N/A'"/></p>
                            
                            <p><strong>Doctors:</strong> 
                                <t t-out="', '.join(patient.doctor_ids.mapped('first_name')) or 'N/A'"/>
                            </p>

                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
